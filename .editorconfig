root = true

[*]
insert_final_newline = true
indent_style = tab
indent_size = 4
trim_trailing_whitespace = true
max_line_length = 120

[*.csproj]
insert_final_newline = true
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
max_line_length = 120

[*.json]
indent_size = 2
indent_style = tab
charset = utf-8
